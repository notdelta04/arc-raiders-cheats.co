---
import { NAV_LINKS, ZADEYO_CHEATS_URL } from '../lib/site';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
---

<nav aria-label="Main navigation">
  <div class="nav-inner">
    <input type="checkbox" id="nav-open" class="nav-check" aria-hidden="true" tabindex="-1" />
    <Logo />
    <ul class="nav-links" id="nav-menu">
      {NAV_LINKS.map((link) => (
        <li>
          <a href={link.href} class:list={{ active: currentPath.startsWith(link.href) }}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <div class="nav-actions">
      <ThemeToggle />
      <a href={ZADEYO_CHEATS_URL} class="nav-cta">Get Access</a>
      <label for="nav-open" class="nav-toggle" aria-label="Toggle menu">
        <Icon name="menu" size={20} />
      </label>
    </div>
  </div>
</nav>
