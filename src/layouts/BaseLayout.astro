---
import '../styles/global.css';
import { SITE, SITE_LOGO_URL, SITE_FONT } from '../lib/site';
import { buildTitle, buildCanonical, trimDescription } from '../lib/seo';
import { organizationSchema, webPageSchema } from '../lib/schema';
import { resolveSocialImage, resolveOgImageUrl } from '../lib/social-images';
import SchemaOrg from '../components/SchemaOrg.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  keywords?: string[];
  articlePublished?: string;
  articleModified?: string;
  lcpImage?: string;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  ogImageAlt,
  noindex = false,
  schema,
  keywords = [],
  articlePublished,
  articleModified,
  lcpImage,
} = Astro.props;

const pageTitle = buildTitle(title);
const metaDescription = trimDescription(description);
const canonicalUrl = canonical ?? buildCanonical(Astro.url.pathname);
const socialImage = resolveSocialImage(Astro.url.pathname);
const ogImageSrc = ogImage ?? socialImage.src;
const ogImageAltText = ogImageAlt ?? socialImage.alt;
const ogImageUrl = resolveOgImageUrl(ogImageSrc, SITE.url);
const jsonLd = [
  organizationSchema(),
  webPageSchema({
    name: pageTitle,
    description: metaDescription,
    url: canonicalUrl,
    image: ogImageUrl,
    imageAlt: ogImageAltText,
    imageWidth: socialImage.width,
    imageHeight: socialImage.height,
  }),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }

        function syncThemeToggle(button) {
          var theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
          button.setAttribute('aria-label', theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode');
          button.classList.toggle('is-light', theme === 'light');
        }

        document.addEventListener('click', function (event) {
          var goTarget = event.target.closest('[data-go-url]');
          if (goTarget) {
            event.preventDefault();
            var goUrl = goTarget.getAttribute('data-go-url');
            if (goUrl) window.location.assign(goUrl);
            return;
          }

          var button = event.target.closest('[data-theme-toggle]');
          if (!button) return;
          var current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch (e) {}
          syncThemeToggle(button);
        });

        document.addEventListener('DOMContentLoaded', function () {
          var button = document.querySelector('[data-theme-toggle]');
          if (button) syncThemeToggle(button);
        });
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content={SITE.author} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="rating" content={SITE.rating} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" href={SITE.logo} sizes="32x32" />
    <link rel="icon" type="image/png" href={SITE.logo} sizes="192x192" />
    <link rel="apple-touch-icon" href={SITE.logo} />
    <link rel="alternate" hreflang="en" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="preload" href={SITE_FONT.preload} as="font" type="font/woff2" crossorigin="anonymous" />
    {lcpImage && (
      <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />
    )}
    <slot name="head" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content={String(socialImage.width)} />
    <meta property="og:image:height" content={String(socialImage.height)} />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:logo" content={SITE_LOGO_URL} />
    <meta property="og:locale" content={SITE.locale} />
    <meta itemprop="name" content={pageTitle} />
    <meta itemprop="description" content={metaDescription} />
    <meta itemprop="logo" content={SITE_LOGO_URL} />
    <meta itemprop="image" content={ogImageUrl} />
    {articlePublished && <meta property="article:published_time" content={articlePublished} />}
    {articleModified && <meta property="article:modified_time" content={articleModified} />}
    {keywords.map((keyword) => (
      <meta property="article:tag" content={keyword} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitter} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <SchemaOrg schema={jsonLd} />
    <link rel="manifest" href="/site.webmanifest" />
  </body>
</html>
