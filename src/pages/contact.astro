---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactPageSchema, breadcrumbSchema } from '../lib/schema';
import { SITE, ZADEYO_CHEATS_URL } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';

const contactSocial = resolveSocialImage('/contact/');

const schema = [
  contactPageSchema(contactSocial.src),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url },
    { name: 'Contact', url: `${SITE.url}/contact/` },
  ]),
];
---

<BaseLayout
  title="Contact Arc Raiders Cheats — Get Access"
  description="Get instant access to Arc Raiders cheats, Cloud DMA, UGC, and HWID Spoofer. Xray, Pro, and Private tiers available."
  schema={schema}
>
  <section class="section listing-section">
    <div class="section-inner">
      <div class="listing-intro">
        <div class="s-tag">// Contact</div>
        <h1>Get Access</h1>
        <p class="listing-intro-desc">
          Ready for Arc Raiders cheats or products? Click below for instant checkout — Xray, Pro,
          Private, Cloud DMA, UGC, and HWID Spoofer.
        </p>
      </div>

      <div class="form-page form-page--inline">
        <button type="button" class="btn-primary" data-go-url={ZADEYO_CHEATS_URL}>Get Access</button>
      </div>
    </div>
  </section>
</BaseLayout>
