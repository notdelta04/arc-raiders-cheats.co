---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/schema';
import { SITE, ZADEYO_CHEATS_URL } from '../lib/site';

const schema = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Privacy Policy', url: `${SITE.url}/privacy-policy/` },
]);
---

<BaseLayout
  title="Privacy Policy — Arc Raiders Cheats"
  description="Privacy policy for ArcRaidersCheats.co — what data we collect when you contact us and how we handle it. No third-party analytics."
  schema={schema}
>
  <section class="section listing-section">
    <div class="section-inner">
      <div class="listing-intro">
        <div class="s-tag">// Legal</div>
        <h1>Privacy Policy</h1>
        <p class="listing-intro-desc">Last updated: June 28, 2026</p>
      </div>

      <div class="legal-content legal-content--inline">
    <p>
      ArcRaidersCheats.co ("we," "us," or "our") operates the website arcraiderscheats.co. This page
      explains how we handle information when you visit our site.
    </p>

    <h2>Information We Collect</h2>
    <p>
      When you use checkout or linked external services, those services may collect the information
      needed to process access. We do not run third-party analytics or advertising trackers on this
      site.
    </p>

    <h2>How We Use Information</h2>
    <p>We use collected information to:</p>
    <ul>
      <li>Provide access and product-related information after checkout</li>
      <li>Improve our content and site performance</li>
      <li>Understand which guides and products are most useful to visitors</li>
      <li>Send product-related communications if you purchased a premium product</li>
    </ul>

    <h2>Local Storage</h2>
    <p>
      We use browser local storage only to remember your light or dark theme preference. No tracking
      cookies are set by this site.
    </p>

    <h2>Third-Party Links</h2>
    <p>
      Our site may contain links to external websites. We are not responsible for the privacy
      practices of those sites. Review their privacy policies before providing personal information.
    </p>

    <h2>Data Retention</h2>
    <p>
      Product access records are retained only as long as needed to provide service and maintain
      account access.
    </p>

    <h2>Your Rights</h2>
    <p>
      You may request access to, correction of, or deletion of personal data through the checkout and
      support flow linked below.
    </p>

    <h2>Changes to This Policy</h2>
    <p>
      We may update this privacy policy from time to time. Changes will be posted on this page with
      an updated date. Continued use of the site after changes constitutes acceptance of the revised
      policy.
    </p>

    <h2>Contact</h2>
    <p>
      Privacy questions or access requests can be started through the button below.
    </p>
    <p>
      <button type="button" class="btn-primary" data-go-url={ZADEYO_CHEATS_URL}>Get Access</button>
    </p>
      </div>
    </div>
  </section>
</BaseLayout>
