---
import BaseLayout from '../layouts/BaseLayout.astro';
import CheatTierCard from '../components/CheatTierCard.astro';
import ProductCard from '../components/ProductCard.astro';
import BlogCard from '../components/BlogCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import LazyVideo from '../components/LazyVideo.astro';
import ShowcaseSlider from '../components/ShowcaseSlider.astro';
import { getCollection } from 'astro:content';
import { cheats, getCheatFeatures } from '../data/cheats';
import { homepageShowcase, homepageHero, homepageHeroImage, homepageShowcaseVideo } from '../data/homepage';
import { homepageGuideIntro, homepageGuideSections, homepageGuideTakeaways } from '../data/homepage-guide';
import { homepageFaqs, products } from '../data/products';
import { ZADEYO_CHEATS_URL, SITE_KEYWORDS } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';
import {
  websiteSchema,
  faqSchema,
  organizationSchema,
  homepageSoftwareApplicationSchema,
  breadcrumbSchema,
} from '../lib/schema';

const homeSocial = resolveSocialImage('/');

const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const schema = [
  homepageSoftwareApplicationSchema(homeSocial.src),
  websiteSchema(),
  organizationSchema(),
  faqSchema([...homepageFaqs], homeSocial.src),
  breadcrumbSchema([
    { name: 'Home', url: 'https://arcraiderscheats.co/' },
    { name: 'Cheats', url: 'https://arcraiderscheats.co/cheats/' },
    { name: 'Products', url: 'https://arcraiderscheats.co/products/' },
    { name: 'Blog', url: 'https://arcraiderscheats.co/blog/' },
  ]),
];
---

<BaseLayout
  title="Arc Raiders Cheats – Undetected ESP, Aimbot & Radar 2026"
  description="Arc Raiders Cheats – Dominate every raid with player ESP, loot ESP, bone-targeted aimbot, 2D radar hack, and extraction intel. Fully external, safe against EAC. Updated every patch."
  schema={schema}
  keywords={[...SITE_KEYWORDS]}
  lcpImage={homepageHeroImage.src}
>
  <section class="hero">
    <div class="hero-bg-photo" aria-hidden="true">
      <img
        src={homepageHeroImage.src}
        alt=""
        width="960"
        height="540"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        sizes="100vw"
      />
    </div>
    <div class="hero-bg"></div>
    <div class="hero-glow hero-glow-left"></div>
    <div class="hero-glow hero-glow-right"></div>
    <div class="hero-slash hero-slash-left"></div>
    <div class="hero-slash2 hero-slash2-left"></div>
    <div class="hero-slash hero-slash-right"></div>
    <div class="hero-slash2 hero-slash2-right"></div>
    <div class="section-inner hero-inner">
      <div class="hero-content hero-animate">
        <div class="hero-badge">{homepageHero.badge}</div>
        <h1>{homepageHero.title}</h1>
        <p class="hero-desc">{homepageHero.description}</p>
        <div class="hero-btns">
          <button type="button" class="btn-primary" data-go-url={ZADEYO_CHEATS_URL}>Browse Cheats</button>
          <a href="/products/" class="btn-ghost">View Products</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section showcase-section alt-bg" id="showcase">
    <div class="section-inner">
      <div class="listing-intro">
        <h2 class="listing-subtitle">See It In Action</h2>
        <p class="listing-intro-desc">
          Real cheat screenshots — ESP, aimbot, radar, and in-game overlays from our ARC Raiders
          tools.
        </p>
      </div>

      <div class="showcase-panel showcase-panel--single">
        <LazyVideo
          src={homepageShowcaseVideo.src}
          poster={homepageShowcaseVideo.poster}
          alt={homepageShowcaseVideo.alt}
        />
        <div class="showcase-media">
          <ShowcaseSlider media={homepageShowcase} />
        </div>
      </div>
    </div>
  </section>

  <section class="section homepage-guide-section" id="guide">
    <div class="section-inner">
      <div class="listing-intro homepage-guide-intro">
        <div class="s-tag">// Guide</div>
        <h2 class="listing-subtitle">Arc Raiders Cheats Guide</h2>
        <p class="listing-intro-desc">
          What to look for when buying Arc Raiders cheats — features, safety, and support without
          the sales pitch.
        </p>
      </div>

      <article class="blog-article blog-article--prose content-main homepage-guide-panel">
        <p class="homepage-guide-intro-text">{homepageGuideIntro}</p>

        <div class="homepage-guide-takeaways">
          <p class="homepage-guide-takeaways-label">Key takeaways</p>
          <ul>
            {homepageGuideTakeaways.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        {homepageGuideSections.map((section) => (
          <section class="homepage-guide-block">
            <h2>{section.title}</h2>
            {section.lead && <p class="homepage-guide-lead">{section.lead}</p>}
            {section.paragraphs.map((paragraph) => (
              <p>
                {paragraph.includes('Zadeyo') ? (
                  <>
                    {paragraph.split('Zadeyo')[0]}
                    <button type="button" class="inline-link-button" data-go-url={ZADEYO_CHEATS_URL}>
                      Zadeyo
                    </button>
                    {paragraph.split('Zadeyo')[1]}
                  </>
                ) : (
                  paragraph
                )}
              </p>
            ))}
            {section.bullets && section.bullets.length > 0 && (
              <ul class="homepage-guide-bullets">
                {section.bullets.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </article>
    </div>
  </section>

  <section class="section" id="cheats">
    <div class="section-inner">
      <div class="s-head">
        <div class="s-tag">// Cheats</div>
        <h2 class="s-title">Arc Raiders Cheats</h2>
        <p class="s-sub">Buy Xray, Pro, or Private — ESP, aimbot, and extraction tools for every raid.</p>
      </div>
      <div class="aff-grid aff-grid-three cheat-grid animate-grid">
        {cheats.map((cheat) => (
          <CheatTierCard
            icon={cheat.icon}
            name={cheat.name}
            description={cheat.description}
            features={getCheatFeatures(cheat.id)}
            tier={cheat.tier}
            featured={cheat.featured}
            href={`/cheats/${cheat.id}/`}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section alt-bg" id="products">
    <div class="section-inner">
      <div class="s-head">
        <div class="s-tag">// Products</div>
        <h2 class="s-title">Arc Raiders Cheats Products</h2>
        <p class="s-sub">Cloud DMA, UGC account tools, and HWID Spoofer for a full Arc Raiders cheats stack.</p>
      </div>
      <div class="aff-grid aff-grid-three animate-grid">
        {products.map((product) => (
          <ProductCard {...product} />
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="section-inner">
      <div class="s-head">
        <div class="s-tag">// FAQ</div>
        <h2 class="s-title">Frequently Asked</h2>
      </div>
      <div class="faq-wrap">
        {homepageFaqs.map((faq) => (
          <FAQAccordion question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <section class="section alt-bg" id="blog">
    <div class="section-inner">
      <div class="s-head">
        <div class="s-tag">// Blog</div>
        <h2 class="s-title">Latest Updates</h2>
        <p class="s-sub">Patch breakdowns, meta analysis, and Arc Raiders cheats guides from our team.</p>
      </div>
      <div class="blog-grid animate-grid">
        {blogPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
            href={`/blog/${post.id}/`}
            icon={post.data.icon}
            readTime={post.data.readTime}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="cta-banner">
        <h2>Ready to Run Arc Raiders Cheats?</h2>
        <p>Get Xray, Pro, or Private access — or add Cloud DMA, UGC, and HWID Spoofer to your setup.</p>
        <button type="button" class="btn-primary" data-go-url={ZADEYO_CHEATS_URL}>Get Access Now</button>
      </div>
    </div>
  </section>
</BaseLayout>
