---
import BaseLayout from '../layouts/BaseLayout.astro';
import MotionFAQ from '../components/react/MotionFAQ';
import MotionReveal from '../components/react/MotionReveal';
import { homepageFaqs } from '../data/products';
import { faqSchema, breadcrumbSchema } from '../lib/schema';
import { SITE, ZADEYO_CHEATS_URL } from '../lib/site';
import { resolveSocialImage } from '../lib/social-images';

const faqSocial = resolveSocialImage('/faq/');

const generalFaqs = [
  ...homepageFaqs,
  {
    question: 'How often is content updated?',
    answer:
      'We review all cheat sheets within 48 hours of major Arc Raiders patches. Blog posts and meta analysis are updated when the meta shifts significantly — usually within a week of balance changes.',
  },
  {
    question: 'Can I suggest a guide topic?',
    answer:
      'Yes. Use the Get Access button to open the checkout and support flow. We prioritize topics that multiple players request.',
  },
  {
    question: 'Do you accept guest contributions?',
    answer:
      'We consider guest guides from experienced players with verifiable in-game experience. Use the Get Access flow if you want to discuss a writing sample or your area of expertise.',
  },
];

const schema = [
  faqSchema(generalFaqs, faqSocial.src),
  breadcrumbSchema([
    { name: 'Home', url: SITE.url },
    { name: 'FAQ', url: `${SITE.url}/faq/` },
  ]),
];
---

<BaseLayout
  title="Arc Raiders Cheats FAQ — Common Questions"
  description="FAQ about Arc Raiders cheats — Xray, Pro, and Private tiers, Cloud DMA, HWID spoofer, access, and Season 1 updates."
  schema={schema}
>
  <section class="section listing-section">
    <div class="section-inner">
      <MotionReveal client:visible>
        <div class="listing-intro">
          <div class="s-tag">// FAQ</div>
          <h1>Frequently Asked Questions</h1>
          <p class="listing-intro-desc">
            Everything you need to know about our cheat sheets, guides, and premium products.
          </p>
        </div>
        <MotionFAQ client:visible items={generalFaqs} />
        <div class="cta-banner" style="margin-top: 2rem;">
          <h2>Need Access?</h2>
          <p>Use the checkout flow for Arc Raiders cheats, products, and support.</p>
          <button type="button" class="btn-primary" data-go-url={ZADEYO_CHEATS_URL}>Get Access</button>
        </div>
      </MotionReveal>
    </div>
  </section>
</BaseLayout>
